{
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=PD_management_DB;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_KEY_MUST_BE_AT_LEAST_32_CHARACTERS",
    "Issuer": "PD_Management_Auth",
    "Audience": "PD_Management_Client",
    "ExpiresInMinutes": 60,
    "DurationInMinutes": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EmailSettings": {
    "SmtpServer": "sandbox.smtp.mailtrap.io",
    "Port": 587,
    "Username": "YOUR_MAILTRAP_USERNAME",
    "Password": "YOUR_MAILTRAP_PASSWORD"
  },
  "ReleaseStageMonitor": {
    "Enabled": true,
    "Cron": "0 * * * *"
  },
  "AllowedHosts": "*"
}